# Authentication (server-only)
AUTH_SECRET=
# email:scrypt:<base64url-salt>:<base64url-hash> (sha256/plaintext yalnız migration uyumluluğu için)
AUTH_USERS=
# Optional multi-tenant map: email=client-alias;email2=other-alias
# Omitted users stay in the migration-compatible "legacy-default" tenant.
AUTH_USER_TENANTS=
# Backfilled legacy-default verisini görecek tek hesap (çok kullanıcılı kurulumda zorunlu)
AUTH_LEGACY_OWNER=

# Supabase (server-only; never prefix these with NEXT_PUBLIC_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=models

# Optional AI audit/summary (server-only)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional web push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
